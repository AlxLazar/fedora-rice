#!/usr/bin/env bash
set -oue pipefail
lua_conf="$HOME/.config/hypr/hyprland.lua"
hyprland_conf="$HOME/.config/hypr/hyprland.conf"
default_conf="/usr/share/hyprland/hyprland.conf"

if [ -f "$lua_conf" ]; then
    Hyprland -c "$lua_conf"
elif [ -f "$hyprland_conf" ]; then
    Hyprland -c "$hyprland_conf"
else
    Hyprland -c "$default_conf"
fi
